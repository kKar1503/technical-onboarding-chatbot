# Copy to .env (or .env.local) and fill in. Keep this file in sync with src/env.js.
# Run `SKIP_ENV_VALIDATION=1` to bypass validation (useful in Docker builds).

# Runtime
NODE_ENV=development

# AWS credentials / region
# In ECS, prefer the task IAM role over static keys; these are for local dev.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# S3 bucket holding knowledge-base source documents for Bedrock KB ingestion
KNOWLEDGE_S3_BUCKET=

# GitLab webhook + API access (repository analysis pipeline)
GITLAB_WEBHOOK_SECRET=
GITLAB_ACCESS_TOKEN=

# SQS queue consumed by src/worker for analysis jobs
SQS_ANALYSIS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/000000000000/onboarding-analysis

# DynamoDB table names (optional; defaults applied in code if unset)
DYNAMODB_TABLE_CONVERSATIONS=onboarding-conversations
DYNAMODB_TABLE_REPOSITORIES=onboarding-repositories
DYNAMODB_TABLE_USERS=onboarding-users

# Bedrock model IDs. Use cross-region inference profiles (us./apac./eu. prefix)
# for newer Claude models. Region must have the model enabled in Bedrock console.
# Chat: fast + cheap (user-facing, latency matters).
# Analysis: slow + accurate (async worker, many tool calls).
BEDROCK_CHAT_MODEL=us.anthropic.claude-haiku-4-5-20251001-v1:0
BEDROCK_ANALYSIS_MODEL=us.anthropic.claude-sonnet-4-5-20250929-v1:0

# Bedrock Knowledge Base (S3 Vectors backend). Provisioned by Terraform; these
# are outputs from `terraform output`. Must match embedding model dimensions.
EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0
EMBEDDING_DIMENSIONS=1024
VECTOR_BUCKET_NAME=onboarding-dev-vectors
VECTOR_BUCKET_ARN=arn:aws:s3vectors:ap-southeast-1:000000000000:bucket/onboarding-dev-vectors
BEDROCK_KB_ROLE_ARN=arn:aws:iam::000000000000:role/onboarding-dev-bedrock-kb
KNOWLEDGE_BUCKET_ARN=arn:aws:s3:::onboarding-knowledge-000000000000
S3_KMS_KEY_ARN=arn:aws:kms:ap-southeast-1:000000000000:key/00000000-0000-0000-0000-000000000000
