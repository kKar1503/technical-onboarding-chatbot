# Copy to .env (or .env.local) and fill in. Keep this file in sync with src/env.js.
# Run `SKIP_ENV_VALIDATION=1` to bypass validation (useful in Docker builds).

# Runtime
NODE_ENV=development

# AWS credentials / region
# In ECS, prefer the task IAM role over static keys; these are for local dev.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# S3 bucket holding knowledge-base source documents for Bedrock KB ingestion
KNOWLEDGE_S3_BUCKET=

# GitLab webhook + API access (repository analysis pipeline)
GITLAB_WEBHOOK_SECRET=
GITLAB_ACCESS_TOKEN=

# SQS queue consumed by src/worker for analysis jobs
SQS_ANALYSIS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/000000000000/onboarding-analysis

# DynamoDB table names (optional; defaults applied in code if unset)
DYNAMODB_TABLE_CONVERSATIONS=onboarding-conversations
DYNAMODB_TABLE_REPOSITORIES=onboarding-repositories
DYNAMODB_TABLE_USERS=onboarding-users
