# Required
environment           = "dev"
gitlab_webhook_secret = "your-webhook-secret-here"
gitlab_access_token   = "glpat-xxxxxxxxxxxxxxxxxxxx"

# Recommended: subscribe an email to CloudWatch alarms (5xx, DLQ depth,
# Bedrock throttles, queue backlog, etc.). Leave empty to skip.
# alarm_email = "ops@example.com"

# Optional overrides
# aws_region           = "ap-southeast-1"
# project_name         = "onboarding"
# vpc_cidr             = "10.0.0.0/16"

# For HTTPS (optional - leave commented out for HTTP-only)
# certificate_arn      = "arn:aws:acm:us-east-1:123456789012:certificate/abc-123"

# ECS sizing
# nextjs_instance_type = "t3.small"   # EC2 instance for Next.js (always-on)
# nextjs_desired_count = 1
# nextjs_max_count     = 2
# worker_cpu           = 1024          # 1 vCPU for Fargate worker
# worker_memory        = 2048          # 2 GB for Fargate worker
# worker_max_count     = 5

# Bedrock models. Use cross-region inference profiles (us./apac./eu. prefix)
# for Claude 4.5 family. Each model must be enabled in the deployment region
# via the Bedrock console.
# bedrock_chat_model     = "us.anthropic.claude-haiku-4-5-20251001-v1:0"
# bedrock_analysis_model = "us.anthropic.claude-sonnet-4-5-20250929-v1:0"
# embedding_model_id     = "amazon.titan-embed-text-v2:0"
# embedding_dimensions   = 1024
